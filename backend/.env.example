# Postgres (system of record)
DATABASE_URL=postgresql+psycopg://catchup:catchup@localhost:5432/catchup

# Signing secret for magic-link tokens + session cookies (use a long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Where the SPA is served (used to build magic-link callback URLs in emails)
APP_BASE_URL=http://localhost:5173

# Notifier: "console" (prints link to logs) | "resend"
NOTIFIER=console
RESEND_API_KEY=
EMAIL_FROM=catch-up <login@example.com>

# Geocoder (komoot Photon — free, no key)
GEOCODER_URL=https://photon.komoot.io

# Object storage (S3-compatible). Local dev = MinIO from docker-compose.dev.yml
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=catchup-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/catchup-photos

# Auth tuning
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30
COOKIE_NAME=catchup_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Rate limits for sign-in link requests
RATELIMIT_EMAIL_PER_HOUR=5
RATELIMIT_IP_PER_HOUR=20

# Photo upload
PHOTO_MAX_BYTES=5242880

LOG_LEVEL=INFO
